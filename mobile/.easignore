# Dependencies are installed by EAS from package-lock.json.
node_modules/

# Local Expo and bundler output.
.expo/
.expo-shared/
.expo-export-smoke/
dist/
build/
coverage/
.cache/
.metro-cache/

# Native folders are generated by Expo/EAS for this managed app.
android/
ios/

# Local backups and source-control metadata are not needed in cloud builds.
.git/
.git-local-backup*/

# Local environment and signing secrets must never be uploaded.
.env
.env.*
!.env.example
*.jks
*.keystore
*.p8
*.p12
*.mobileprovision

# Local build artifacts.
*.apk
*.aab
*.ipa
*.apks

# Logs and temporary files.
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log
*.tmp
*.temp

# Generated Expo/TypeScript helper.
expo-env.d.ts
