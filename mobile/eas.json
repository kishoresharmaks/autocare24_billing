{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "image": "latest"
      }
    },
    "ios-simulator": {
      "ios": {
        "simulator": true,
        "image": "latest"
      }
    },
    "production": {
      "autoIncrement": true
    }
  }
}
